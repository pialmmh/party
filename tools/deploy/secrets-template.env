# Template for ~/.secrets/party-<operator>.env  (e.g. party-btcl.env)
# ---------------------------------------------------------------------
# Copy to ~/.secrets/party-<operator>.env, fill in real values, then:
#   chmod 600 ~/.secrets/party-<operator>.env
#
# Generate a fresh DB password:
#   openssl rand -base64 24 | tr -d '/+=' | head -c 32
#
# Generate the JWT signing key (32+ bytes):
#   openssl rand -base64 32
#
# Generate the Keycloak SPI shared secret:
#   openssl rand -base64 32
#
# DO NOT check these values into git. DO NOT bake them into the uber JAR.
# They are read by remote-deploy.sh and written to /etc/party/party.env on the
# target host only (root:party, chmod 640).

PARTY_DB_PASSWORD=
PARTY_JWT_SECRET=
PARTY_KC_INTEGRATION_SECRET=

# Optional — only needed if PARTY_KC_ADMIN_ENABLED=true in profile-prod.yml
PARTY_KC_ADMIN_PASS=
