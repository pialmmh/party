<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 http://maven.apache.org/xsd/maven-4.0.0.xsd">
    <modelVersion>4.0.0</modelVersion>

    <parent>
        <groupId>com.telcobright.party</groupId>
        <artifactId>party-parent</artifactId>
        <version>0.1.0-SNAPSHOT</version>
    </parent>

    <artifactId>party-v2</artifactId>
    <name>Party :: V2 (stateless adapters + policy chain)</name>
    <description>
        Stateless redesign of Party: pluggable UserRepoAdapter (Odoo / Routesphere / LDAP / Custom)
        per tenant + configurable policy chain. The legacy DB-backed modules
        remain alongside for now; v2 is opt-in via the /v2/* REST surface.
        Exception to statelessness: the secure-link registration feature owns the small
        device_registry + transient OTP store (frozen-interfaces §2).
    </description>

    <dependencies>
        <!-- CDI + config -->
        <dependency>
            <groupId>io.quarkus</groupId>
            <artifactId>quarkus-arc</artifactId>
        </dependency>
        <dependency>
            <groupId>io.quarkus</groupId>
            <artifactId>quarkus-rest</artifactId>
        </dependency>
        <dependency>
            <groupId>io.quarkus</groupId>
            <artifactId>quarkus-rest-jackson</artifactId>
        </dependency>
        <dependency>
            <groupId>io.smallrye.config</groupId>
            <artifactId>smallrye-config</artifactId>
        </dependency>

        <!-- Jackson is used directly for Odoo JSON-RPC -->
        <dependency>
            <groupId>com.fasterxml.jackson.core</groupId>
            <artifactId>jackson-databind</artifactId>
        </dependency>

        <!-- device_registry persistence (secure-link registration feature) -->
        <dependency>
            <groupId>io.quarkus</groupId>
            <artifactId>quarkus-agroal</artifactId>
        </dependency>
        <dependency>
            <groupId>io.quarkus</groupId>
            <artifactId>quarkus-jdbc-mysql</artifactId>
        </dependency>

        <!-- NATS JetStream — the per-account contact-event feed (SL_CONTACTS) -->
        <dependency>
            <groupId>io.nats</groupId>
            <artifactId>jnats</artifactId>
            <version>2.20.5</version>
        </dependency>

        <!-- OpenBao (Vault-API compatible) dev secret store: AppRole-read the HS256
             key + party DB creds at startup. No secret in env/git/scp (secure-link
             secrets decision, 2026-06-15). On Quarkus 3.15.1 LTS: 4.1.0 (built for
             3.12) leaves VaultRuntimeConfig null at runtime; 4.2.0 (3.19) records the
             runtime config correctly here. -->
        <dependency>
            <groupId>io.quarkiverse.vault</groupId>
            <artifactId>quarkus-vault</artifactId>
            <version>4.2.0</version>
        </dependency>

        <!-- Test -->
        <dependency>
            <groupId>io.quarkus</groupId>
            <artifactId>quarkus-junit5</artifactId>
            <scope>test</scope>
        </dependency>
    </dependencies>

    <build>
        <plugins>
            <!-- Augment + package the runnable Quarkus app (was only in pluginManagement,
                 so `mvn package` produced a thin jar; bind the build goal so it yields the
                 runnable uber-jar). -->
            <plugin>
                <groupId>${quarkus.platform.group-id}</groupId>
                <artifactId>quarkus-maven-plugin</artifactId>
                <extensions>true</extensions>
                <executions>
                    <execution>
                        <goals>
                            <goal>build</goal>
                            <goal>generate-code</goal>
                            <goal>generate-code-tests</goal>
                        </goals>
                    </execution>
                </executions>
            </plugin>
            <!-- Index this module so Quarkus discovers CDI beans + @ConfigMapping. -->
            <plugin>
                <groupId>io.smallrye</groupId>
                <artifactId>jandex-maven-plugin</artifactId>
                <version>3.2.2</version>
                <executions>
                    <execution>
                        <id>make-index</id>
                        <goals>
                            <goal>jandex</goal>
                        </goals>
                    </execution>
                </executions>
            </plugin>
        </plugins>
    </build>
</project>
